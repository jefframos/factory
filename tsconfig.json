{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": [
        "core/*"
      ],
      "three/*": [
        "node_modules/three/*"
      ]
    },
    "outDir": "dist",
    "strict": true
  },
  "include": [
    "games",
    "core",
    "scripts"
  ]
}